# Is This Phishy? — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Runtime ───────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=WARNING
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# For local dev:
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# For production (Railway):
# ALLOWED_ORIGINS=https://isthisphishy.com.au,https://isthisphishy.vercel.app

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=100
RATE_WINDOW=60

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=1048576
MAX_LINES_PER_FILE=500
MAX_CHARS_PER_LINE=500

# ── Batch analysis ────────────────────────────────────────────────────────────
MAX_BATCH_SIZE=100

# ── Database ──────────────────────────────────────────────────────────────────
# Path to directory where analytics.db will be created.
# On Railway: set to a persistent volume mount path.
# PHISHY_DATA_DIR=/data

# ── Admin ─────────────────────────────────────────────────────────────────────
# Optional token to protect the /api/report endpoint.
# Leave empty for public access.
# ADMIN_TOKEN=your-secret-token-here

# ── Split deployment (Vercel frontend + Railway backend) ─────────────────────
# Set this on Railway when using a separate Vercel frontend.
# API_BASE_URL=https://isthisphishy-production.up.railway.app
